SEVEN_CONTROL_LOCATION_SERVER_URL=http://seven-control-admin.example.local:8765
SEVEN_CONTROL_LOCATION_TOKEN=change-me-enroll-token
SEVEN_CONTROL_DEVICE_NAME=
SEVEN_CONTROL_DEVICE_ID=

# Optionnel. Si vide, l'agent utilise le chemin par defaut de l'OS:
# Linux: /etc/seven-control/location-notice.accepted
# Windows: C:\ProgramData\SevenControl\location-notice.accepted
# macOS: /Library/Application Support/SevenControl/location-notice.accepted
# SEVEN_CONTROL_LOCATION_NOTICE_FILE=

# Optionnel. Laissez vide pour eviter tout appel externe.
# Exemple interne recommande: https://mdm.example.local/ip
SEVEN_CONTROL_PUBLIC_IP_URL=
